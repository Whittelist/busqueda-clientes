DEEPSEEK_API_KEY=sk-tu-api-key-aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Dry run: true = solo simula (no escribe en Sheet), false = escribe de verdad
DRY_RUN=true

# Limite de empresas por ejecucion
MAX_COMPANIES_PER_RUN=25

# Segundos de espera entre empresas (para no saturar DeepSeek ni las webs)
DELAY_BETWEEN_COMPANIES=3
